# Database configuration
DATABASE_URL=""

# NextAuth configuration
NEXTAUTH_SECRET=""
NEXTAUTH_URL="https://example.com/digisales"
NEXTAUTH_URL_INTERNAL="http://127.0.0.1:3000/digisales"
TRUST_HOST=true

# Sub-path hosting (production). Set to "/cbas" to serve at digixworkspace.com/cbas.
# Leave EMPTY for local dev (app stays at the root "/"). Must be set before `npm run build`.
# When set, also set NEXTAUTH_URL to include the path, e.g. https://digixworkspace.com/cbas
NEXT_PUBLIC_BASE_PATH=""

# Gemini API key (for the AI assistant chatbot) — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# CBAS AI Engine (Python/FastAPI service in /ai-engine) — serves the trained ML models.
# Start it with:  cd ai-engine && uvicorn app.main:app --port 8088
AI_ENGINE_URL="http://127.0.0.1:8088"
# Must match AI_ENGINE_API_KEY in ai-engine/.env (leave blank to disable the check in dev)
AI_ENGINE_API_KEY=""

# Webhook Secrets
WP_WEBHOOK_SECRET=""
META_WEBHOOK_VERIFY_TOKEN=""
LINKEDIN_WEBHOOK_SECRET=""
UPWORK_WEBHOOK_SECRET=""

# WhatsApp API
WHATSAPP_PHONE_ID=""
WHATSAPP_ACCESS_TOKEN=""

# NextAuth Email (Magic Link) Provider Details
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM=""

# NextAuth Google Provider Details
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Administrative contact
SUPER_ADMIN_EMAIL=""
RECOVERY_EMAIL=""

# Stripe Configuration
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Stripe Price IDs (Required for Subscriptions)
STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_YEARLY=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
STRIPE_PRICE_ENT_MONTHLY=""
STRIPE_PRICE_ENT_YEARLY=""

# Turnstile Configuration
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Square Gateway Configuration (Internal SaaS Billing)
SQUARE_ACCESS_TOKEN=""
SQUARE_LOCATION_ID=""
SQUARE_PLAN_STARTER_MONTHLY="plan_starter_monthly_id"
SQUARE_PLAN_STARTER_YEARLY="plan_starter_yearly_id"
SQUARE_PLAN_PRO_MONTHLY="plan_pro_monthly_id"
SQUARE_PLAN_PRO_YEARLY="plan_pro_yearly_id"
SQUARE_PLAN_ENT_MONTHLY="plan_ent_monthly_id"
SQUARE_PLAN_ENT_YEARLY="plan_ent_yearly_id"
