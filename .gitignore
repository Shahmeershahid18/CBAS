# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Database and Sensitive Files
*.sql
*.dump
*.sqlite
*.db*
*.docx
*.log
/tmp/

# IDE
/.idea/

# Claude Code local session state
/.claude/

# Android (Capacitor) - build output, not committed for now
/android/

# Backups / archives / compiled binaries
*.zip
*.apk

# Stray lint output
eslint_errors.txt

# ---- Python / AI Engine ----
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Trained models, datasets, and caches (regenerated via training scripts)
/ai-engine/.venv/
/ai-engine/artifacts/*.joblib
/ai-engine/artifacts/*.json
/ai-engine/artifacts/sentiment_bert/
/ai-engine/artifacts/_bert_ckpt/
/ai-engine/data/*.csv
.cache/

# Editor
/.vscode/
*.swp

# Old project kept only for rebrand reference — do not commit/deploy
CBAS-old/
