# CBAS AI Engine configuration

# Host/port the FastAPI service binds to
AI_ENGINE_HOST=127.0.0.1
AI_ENGINE_PORT=8088

# Shared secret. The Next.js backend must send this as the `x-ai-engine-key`
# header on every request. Leave blank to disable the check (dev only).
AI_ENGINE_API_KEY=

# Directory holding trained model artifacts (relative to ai-engine/)
ARTIFACTS_DIR=artifacts
